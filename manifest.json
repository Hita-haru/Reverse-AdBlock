{
    "manifest_version": 3,
    "name": "Reverse Ad block",
    "version": "1.1.0",
    "description": "逆広告ブロッカーです。擬似的な広告を表示します",
    "web_accessible_resources": [
        {
            "resources": ["rectangle-ad/*", "banner-ad/*"],
            "matches": ["<all_urls>"]
        }
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["style.css"]
        }
    ],
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}