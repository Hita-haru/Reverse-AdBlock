{
    "manifest_version": 3,
    "name": "Reverse Ad block",
    "version": "1.0.0",
    "description": "逆広告ブロッカーです。擬似的な広告を表示します",
    "web_accessible_resources": [
        {
            "resources": ["rectangle-ad/*", "banner-ad/*"],
            "matches": ["<all_urls>"]
        }
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["style.css"]
        }
    ]
}
